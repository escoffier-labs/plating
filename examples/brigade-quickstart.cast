[13.41, "o", "content_guard: installed hook=configured-hooks-path policy=public-repo\r\n"]
[13.47, "o", "local_only:\r\n"]
[13.53, "o", "- .brigade/ stores local config, receipts, scans, reports, waivers, and run artifacts.\r\n"]
[13.59, "o", "- Brigade does not run automatically, start daemons, activate hooks, send notifications, publish, push, tag, or mutate remotes.\r\n"]
[13.65, "o", "tracked_vs_generated:\r\n"]
[13.71, "o", "- Track reviewed cross-harness source docs under tools/.\r\n"]
[13.77, "o", "- Generated harness projections and handoff inboxes under .claude/, .codex/, .opencode/, .antigravity/, .pi/, .cursor/, .aider/, .goose/, .continue/, .copilot/, .qwen/, .kimi/, .adal/, .openhands/, .grok/, .amp/, .crush/, .hermes/, .openclaw/, .mcp/, and scripts/ are local ignored state.\r\n"]
[13.83, "o", "- Run brigade operator sync-tools --target . after changing tracked tool sources.\r\n"]
